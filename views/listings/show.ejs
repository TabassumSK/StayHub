 <style>
  .show-img {
    height: 450px;
    /* width: 90%; */
    object-fit: cover;
  }

  #map {
    height: 450px;
    width: 90%;
  }

  .map-box {
    margin: 3rem;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .map-nm{
    font-size: 1.5rem;
  }

  .listing-content {
    padding: 2rem 0 0 1.5rem;
    font-size: 1rem;
  }

  .content {
    display: block;
    gap: 2rem;
    font-weight: 450;
  }

  .content b {
    font-weight: 600;
  }

  .review-container {
    margin: 2rem 6rem 4rem 6rem;
    max-width: 85%;
  }

  /* Parent container */
  .reviews-wrapper {
    display: flex;
    flex-wrap: wrap;
    /* allows next row */
    gap: 20px;
    /* space between cards */
  }

  /* Each review card */
  .review-card {
    flex: 0 0 calc(50% - 10px);
    /* 2 per row */
  }

  /* Responsive for mobile */
  @media (max-width: 768px) {
    .review-card {
      flex: 0 0 100%;
      /* 1 per row on mobile */
    }
  }

  /* Main Review Container */
  .rating-container {
    max-width: 70%;
    margin: 40px auto;
  }

  /* Make form look like a card */
  .rating-container form {
    background: #ffffff;
    padding: 15px 20px;
    border-radius: 16px;
    border: 2px solid rgb(222, 217, 217);
    transition: 0.3s ease;
  }

  /* Smooth hover effect */
  .rating-container form:hover {
    transform: translateY(-3px);
  }

  /* Improve heading spacing */
  .rating-container h4 {
    margin-bottom: 20px;
  }

  /* Better textarea look */
  .rating-container textarea {
    border-radius: 10px;
    padding: 12px;
    resize: none;
  }

  /* Better submit button */
  .rating-container button {
    border-radius: 30px;
    padding: 8px 25px;
    font-weight: 500;
    transition: 0.3s ease;
    background-color: black;
    color: white;
  }

  /* Remove harsh hr look */
  .rating-container hr {
    opacity: 0.1;
  }

  /* comment box */
  .cmt-box {
    border: 1px solid rgb(171, 167, 167);
  }

  .location-icon {
    font-size: 1rem;
  }

  .reviewer-profile {
    display: flex;
    flex-direction: row;
    padding-bottom: 0.3rem;
  }

  .fa-circle-user {
    font-size: 1.5rem;
    color: #0D6EFD;
    margin-right: 0.3rem;
  }

  .show-btns {
    margin-top: 1rem;
  }
</style>




<% layout('/layouts/boilerplate') %>

<div class="container mt-4">


  <h2 class="fw-bold mb-4 text-center"><%= listing.title %></h2>


  <div class="row p-4 rounded">


    <div class="col-md-7">
      <img src="<%= listing.image.url %>" class="img-fluid w-100 rounded shadow-sm show-img" alt="listing_image">
    </div>


    <div class="col-md-5 listing-content">
      <p>
        <span class="content"><b>Owned By:</b>
          <%= listing.owner.username %></span>
      </p>

      <p><span class="content"><b>Description:</b>
          <%= listing.description %></span>
      </p>

      <p><span class="content"><b>Price:</b>
          ₹ <%= listing.price.toLocaleString("en-IN") %> / night</span>
      </p>

      <p>
        <span class="content">
          <b>Location:</b>
          <i class="fa-solid fa-location-dot location-icon"></i>
          <%= listing.location %>
        </span>
      </p>

      <p>
        <span class="content">
          <b>Country: </b>
          <i class="fa-solid fa-globe location-icon"></i>
          <%= listing.country %>
        </span>
      </p>

      <% if (listing.services) { %>
      <p>
        <span class="content">
          <b>Services: </b>
          <%= listing.services %>
        </span>
      </p>
      <% } %>



      <% if (currUser && listing.owner._id.equals(currUser._id)) { %>

      <div class="d-flex gap-3 mt-4">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">Edit</a>

        <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
          <button class="btn btn-dark">Delete</button>
        </form>
      </div>
      <% } %>
    </div>

  </div>

  <hr />


  <div class="review-container">
    <% if(listing.reviews.length > 0) { %>
    <div class="review-container">
      <h4 class="fw-bold mb-3">All Reviews</h4>

      <div class="reviews-wrapper">
        <% for (let review of listing.reviews) { %>

        <div class="review-card">
          <div class="card shadow-sm h-100">
            <div class="p-3">
              <div class="reviewer-profile">
                <i class="fa-solid fa-circle-user"></i>
                <h6 class="fw-bold">@<%= review.author.username %></h6>
              </div>

              <p class="starability-result" data-rating="<%= review.rating %>"></p>

              <p><%= review.comment %></p>

              <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-sm btn-dark">Delete</button>
              </form>
            </div>
          </div>
        </div>
        <% } %>
      </div>
    </div>
    <% } %>
  </div>


  <div class="mt-5 rating-container">

    <% if (currUser) { %>
    <h4 class="fw-bold">Leave a Review</h4>

    <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">

      <div>
        <label for="rating" class="form-label fw-bold">Rating</label>
        <fieldset class="starability-slot">
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
          <input type="radio" id="first-rate1" name="review[rating]" value="1" />
          <label for="first-rate1" title="Terrible">1 star</label>
          <input type="radio" id="first-rate2" name="review[rating]" value="2" />
          <label for="first-rate2" title="Not good">2 stars</label>
          <input type="radio" id="first-rate3" name="review[rating]" value="3" />
          <label for="first-rate3" title="Average">3 stars</label>
          <input type="radio" id="first-rate4" name="review[rating]" value="4" />
          <label for="first-rate4" title="Very good">4 stars</label>
          <input type="radio" id="first-rate5" name="review[rating]" value="5" />
          <label for="first-rate5" title="Amazing">5 stars</label>
        </fieldset>
      </div>

      <div class="mb-3">
        <label class="form-label fw-bold">Comment</label>
        <textarea name="review[comment]" class="form-control cmt-box" rows="4" required></textarea>
        <div class="invalid-feedback">
          Please add some comments for review
        </div>
      </div>

      <button class="btn btn-outline-dark">Submit</button>
    </form>
    <% } %>
  </div>

  <hr />



  <div class="mt-5 map-box">
    <h4 class="fw-bold mb-4 map-nm">Where you'll be</h4>
    <div id="map" class="rounded shadow"></div>
  </div>

</div>



<script>
  const MAP_TOKEN = "<%= MAP_TOKEN %>";
  const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
</script>

<script src="/js/map.js"></script>

